# ==================== AI ASSET MANAGER BOT ====================
# Copy this file to .env and fill in your values

# Solana keypair (base58 private key or path to JSON file)
# Generate: solana-keygen new --outfile wallet.json
SOLANA_KEYPAIR_PATH=./wallet.json
# OR use base58 private key directly:
# SOLANA_PRIVATE_KEY=your_base58_private_key_here

# Solana RPC (mainnet-beta for real trading, devnet for testing)
SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Strategy: 0=Conservative, 1=Moderate, 2=Aggressive
STRATEGY=1

# Trading interval in seconds (default: 300 = 5 minutes)
TRADE_INTERVAL=300

# Initial simulation capital in USD
INITIAL_CAPITAL=10000

# Enable real Jupiter swaps (true/false) — USE WITH CAUTION
ENABLE_REAL_SWAPS=false

# Maximum trade size in USD
MAX_TRADE_USD=500

# Slippage tolerance in basis points (50 = 0.5%)
SLIPPAGE_BPS=50

# Telegram notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REPORT_INTERVAL_MIN=60

# Coins to trade (comma-separated CoinGecko IDs)
COINS=bitcoin,ethereum,solana,bonk,jupiter,raydium

# Telegram Mini App URL (deployed frontend URL for /app command)
# Deploy to Vercel/Netlify first, then set this URL
WEB_APP_URL=

# State file path (for portfolio persistence)
STATE_FILE=./bot-state.json

# Log level: debug, info, warn, error
LOG_LEVEL=info
